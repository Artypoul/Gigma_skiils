{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "diff_summary",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "fail",
        "changed-source",
        "not-tested",
        "manual-review"
      ]
    },
    "viewports": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "environment": {
      "type": "object"
    },
    "issues": {
      "type": "array"
    }
  },
  "required": [
    "result",
    "viewports"
  ]
}
