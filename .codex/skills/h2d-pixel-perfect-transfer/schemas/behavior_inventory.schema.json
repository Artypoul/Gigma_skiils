{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "behavior_inventory",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "result": {
      "type": "string",
      "enum": [
        "pass",
        "partial",
        "fail",
        "not-tested"
      ]
    },
    "url": {
      "type": "string"
    },
    "viewports": {
      "type": "array",
      "items": {
        "type": "integer"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "component_id",
          "selector",
          "kind"
        ],
        "properties": {
          "component_id": {
            "type": "string"
          },
          "selector": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "criticality": {
            "type": "string",
            "enum": [
              "critical",
              "normal",
              "decorative"
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "required": [
    "result",
    "components"
  ]
}
